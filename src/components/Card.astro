---
interface Props {
  title: string;
  description?: string;
  href?: string;
  meta?: string;
}
const { title, description, href, meta } = Astro.props;
---
<article class="card reveal">
  <h3>{href ? <a href={href}>{title}</a> : title}</h3>
  {meta && <small>{meta}</small>}
  {description && <p>{description}</p>}
</article>
<style>
  h3 { margin: 0 0 .5rem; }
  p { margin: .5rem 0 0; color: var(--muted); }
  small { color: var(--muted); }
</style>
