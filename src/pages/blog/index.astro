---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const tags = [...new Set(posts.flatMap((post) => post.data.tags))];
---

<BaseLayout title="Blog">
  <h1 class="reveal">Blog</h1>

  <div class="card reveal controls">
    <input id="search" type="search" placeholder="記事タイトルで検索" aria-label="記事検索" />
    <select id="tag" aria-label="タグ絞り込み">
      <option value="">すべてのタグ</option>
      {tags.map((tag) => <option value={tag}>{tag}</option>)}
    </select>
  </div>

  <div id="posts" class="grid">
    {posts.map((post) => (
      <article class="card reveal" data-tags={post.data.tags.join(',')} data-title={post.data.title.toLowerCase()}>
        <h2><a href={`/blog/${post.slug}`}>{post.data.title}</a></h2>
        <small>{post.data.pubDate.toLocaleDateString('ja-JP')}</small>
        <p>{post.data.description}</p>
      </article>
    ))}
  </div>
</BaseLayout>

<script is:inline>
  const search = document.getElementById('search');
  const tag = document.getElementById('tag');
  const cards = [...document.querySelectorAll('#posts article')];

  function applyFilter() {
    const q = (search?.value || '').toLowerCase().trim();
    const t = tag?.value || '';

    cards.forEach((card) => {
      const title = card.dataset.title || '';
      const tags = (card.dataset.tags || '').split(',').filter(Boolean);
      const okTitle = title.includes(q);
      const okTag = !t || tags.includes(t);
      card.style.display = okTitle && okTag ? 'block' : 'none';
    });
  }

  search?.addEventListener('input', applyFilter);
  tag?.addEventListener('change', applyFilter);
</script>

<style>
  .controls {
    display: grid;
    gap: 0.75rem;
    margin-bottom: 1rem;
  }

  input,
  select {
    border: 1px solid var(--border);
    border-radius: 10px;
    background: color-mix(in srgb, var(--surface), transparent 7%);
    color: var(--text);
    padding: 0.6rem 0.7rem;
  }

  h2 {
    margin: 0;
  }

  small,
  p {
    color: var(--muted);
  }

  p {
    margin: 0.4rem 0 0;
  }
</style>
