---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Card from '../components/Card.astro';
import { fetchNotes } from '../lib/notes';

const blogs = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const latestNews = (await getCollection('news'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const workFiles = import.meta.glob('/src/content/works/*.md');
const works = Object.keys(workFiles).length > 0
  ? (await getCollection('works')).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  : [];

const notes = await fetchNotes();
const latestNotes = notes.slice(0, 3);
---

<BaseLayout title="Home">
  <section class="hero reveal">
    <p class="eyebrow">Personal site</p>
    <h1>ojochiの作業部屋</h1>
    <p>開発メモ、制作の進捗、アップデートを静かに積み上げる場所です。</p>
  </section>

  <div class="section-title reveal">
    <h2>Latest News</h2>
    <a href="/news">一覧へ</a>
  </div>
  <section class="grid cols-3">
    {latestNews.length === 0 ? (
      <Card title="更新準備中" description="最初のニュースを準備しています。" />
    ) : (
      latestNews.map((item) => (
        <Card
          title={item.data.title}
          description={item.data.description}
          href="/news"
          meta={item.data.pubDate.toLocaleDateString('ja-JP')}
        />
      ))
    )}
  </section>

  <div class="section-title reveal">
    <h2>Latest Blog</h2>
    <a href="/blog">一覧へ</a>
  </div>
  <section class="grid cols-3">
    {blogs.map((post) => (
      <Card
        title={post.data.title}
        description={post.data.description}
        href={`/blog/${post.slug}`}
        meta={post.data.pubDate.toLocaleDateString('ja-JP')}
      />
    ))}
  </section>

  <div class="section-title reveal">
    <h2>Latest Note</h2>
    <a href="/note">一覧へ</a>
  </div>
  <section class="grid cols-3">
    {latestNotes.length === 0 ? (
      <Card title="note準備中" description="RSS取得後に最新noteを表示します。" />
    ) : (
      latestNotes.map((note) => (
        <Card
          title={note.title}
          description={note.description}
          href={note.link}
          meta={new Date(note.pubDate).toLocaleDateString('ja-JP')}
        />
      ))
    )}
  </section>

  <div class="section-title reveal">
    <h2>Works</h2>
    <a href="/works">一覧へ</a>
  </div>
  <section>
    {works.length === 0 ? (
      <Card title="Coming soon" description="作品を追加すると自動で一覧に切り替わります。" />
    ) : (
      <Card
        title={works[0].data.title}
        description={works[0].data.description}
        href={works[0].data.link}
        meta={works[0].data.pubDate.toLocaleDateString('ja-JP')}
      />
    )}
  </section>
</BaseLayout>

<style>
  .hero {
    background: color-mix(in srgb, var(--surface), transparent 2%);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    box-shadow: var(--shadow);
    padding: 1.35rem;
  }

  .hero h1 {
    margin: 0.14rem 0 0.35rem;
    color: var(--text-strong);
    font-size: clamp(1.5rem, 4vw, 2.1rem);
  }

  .hero p {
    margin: 0;
    color: var(--muted);
  }

  .eyebrow {
    color: var(--accent-strong);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-size: 0.76rem;
  }
</style>
