---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getNewsDate, sortNews } from '../../lib/news';

const newsList = sortNews(await getCollection('news', ({ data }) => !data.draft));
---

<BaseLayout title="News">
  <h1 class="reveal">News</h1>

  <ol class="timeline">
    {newsList.map((item) => (
      <li class="card reveal">
        <time>{getNewsDate(item).toLocaleDateString('ja-JP')}</time>
        <h2>{item.data.title}</h2>
        <p>{item.data.description}</p>
      </li>
    ))}
  </ol>
</BaseLayout>

<style>
  .timeline {
    list-style: none;
    padding: 0;
    margin: 1rem 0 0;
    display: grid;
    gap: 1rem;
  }

  time,
  p {
    color: var(--muted);
  }

  h2 {
    margin: 0.3rem 0;
  }

  p {
    margin: 0;
  }
</style>
