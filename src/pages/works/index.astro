---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const works = (await getCollection('works')).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---
<BaseLayout title="Works">
  <h1 class="reveal">Works</h1>
  {works.length === 0 ? (
    <section class="card reveal"><h2>Coming soon</h2><p>まだ作品はありません。追加されたら自動で一覧表示されます。</p></section>
  ) : (
    <section class="grid cols-2">
      {works.map((work) => (
        <article class="card reveal">
          <h2>{work.data.link ? <a href={work.data.link}>{work.data.title}</a> : work.data.title}</h2>
          <p>{work.data.description}</p>
        </article>
      ))}
    </section>
  )}
</BaseLayout>
